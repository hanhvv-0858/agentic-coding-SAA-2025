# Public site URL — used as the Supabase OAuth `redirectTo` origin.
# In local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Supabase — safe-for-client values (the anon key is designed for client use
# when RLS is enforced). Get these from your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only secret. NEVER expose to the client. Only server
# components, Route Handlers, and middleware may read this.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of email domains allowed to sign in (constitution
# Principle IV + spec FR-005). Example: sun-asterisk.com,sun-asterisk.vn
ALLOWED_EMAIL_DOMAINS=sun-asterisk.com

# SITE LAUNCH — the moment the SAA site opens (registration + kudo compose
# enabled). While unset OR in the past, `/` is rewritten to `/countdown` and
# direct access to `/countdown` redirects to `/login`. Independent of the
# ceremony date. ISO 8601 UTC.
NEXT_PUBLIC_SITE_LAUNCH_AT=2025-12-01T03:00:00Z

# CEREMONY — the moment the SAA awards night takes place. Powers the
# Homepage About-SAA hero countdown + "Coming soon" subtitle. Independent of
# the site-launch date; MUST be >= NEXT_PUBLIC_SITE_LAUNCH_AT when both set.
# ISO 8601 UTC.
NEXT_PUBLIC_CEREMONY_AT=2025-12-26T11:30:00Z
