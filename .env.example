# Public site URL — used as the Supabase OAuth `redirectTo` origin.
# In local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Supabase — safe-for-client values (the anon key is designed for client use
# when RLS is enforced). Get these from your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only secret. NEVER expose to the client. Only server
# components, Route Handlers, and middleware may read this.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of email domains allowed to sign in (constitution
# Principle IV + spec FR-005). Example: sun-asterisk.com,sun-asterisk.vn
ALLOWED_EMAIL_DOMAINS=sun-asterisk.com

# SAA 2025 event kickoff — ISO 8601 UTC. Drives the Homepage countdown.
# Figma shows 26/12/2025 as the visible date; time-of-day pending Product
# confirmation (spec Q3). Default placeholder: 2025-12-26T11:30:00Z.
NEXT_PUBLIC_EVENT_START_AT=2025-12-26T11:30:00Z
